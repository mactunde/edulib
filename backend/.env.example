# ─── Supabase ───────────────────────────────────────────
# Get these from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── JWT ────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-secret-string-min-64-chars
JWT_EXPIRES_IN=7d

# ─── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Admin Bootstrap ────────────────────────────────────
# Initial admin credentials (used once to seed admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe_Str0ng!

# ─── Frontend URL (for CORS) ────────────────────────────
FRONTEND_URL=http://localhost:3000
